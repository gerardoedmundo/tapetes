                        <span id="cert-dims" class="font-bold text-indigo text-xs sm:text-sm">1.80m x 2.40m</span>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:justify-between border-b border-indigo/10 pb-2 gap-0.5">
                        <span class="text-indigo/60 uppercase text-[10px] font-bold">Densidad Estimada:</span>
                        <span id="cert-knots" class="font-extrabold text-terracota text-sm">604,800 nudos</span>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:justify-between pb-1 gap-0.5">
                        <span class="text-indigo/60 uppercase text-[10px] font-bold">Tiempo de Dedicación:</span>
                        <span id="cert-time" class="font-bold text-indigo text-xs sm:text-sm">~181 Días de Labor en Telar</span>
